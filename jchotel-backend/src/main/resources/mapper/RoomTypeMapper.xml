<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jchotel.mapper.RoomTypeMapper">

    <resultMap id="RoomTypeMap" type="com.jchotel.entity.RoomType">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="bedType" column="bed_type"/>
        <result property="capacity" column="capacity"/>
        <result property="weekendPrice" column="weekend_price"/>
        <result property="memberPrice" column="member_price"/>
        <result property="description" column="description"/>
        <result property="facilities" column="facilities"/>
        <result property="imageUrl" column="image_url"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="findAll" resultMap="RoomTypeMap">
        SELECT * FROM t_room_type ORDER BY id
    </select>

</mapper>
