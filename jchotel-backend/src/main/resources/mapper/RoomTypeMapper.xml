<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jchotel.mapper.RoomTypeMapper">

    <resultMap id="RoomTypeMap" type="com.jchotel.entity.RoomType">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="bedType" column="bed_type"/>
        <result property="capacity" column="capacity"/>
        <result property="weekendPrice" column="weekend_price"/>
        <result property="memberPrice" column="member_price"/>
        <result property="description" column="description"/>
        <result property="facilities" column="facilities"/>
        <result property="imageUrl" column="image_url"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <update id="update">
        UPDATE t_room_type
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="bedType != null">bed_type = #{bedType},</if>
            <if test="capacity != null">capacity = #{capacity},</if>
            <if test="weekendPrice != null">weekend_price = #{weekendPrice},</if>
            <if test="memberPrice != null">member_price = #{memberPrice},</if>
            <if test="description != null">description = #{description},</if>
            <if test="facilities != null">facilities = #{facilities},</if>
            <if test="imageUrl != null">image_url = #{imageUrl}</if>
        </set>
        WHERE id = #{id}
    </update>

</mapper>
